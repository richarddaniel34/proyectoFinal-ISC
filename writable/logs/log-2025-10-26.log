INFO - 2025-10-26 04:25:09 --> [INSCRIP] SQL:
SELECT `c`.`id`, `cb`.`nombre_curso`, `c`.`capacidad`, SUM(CASE WHEN i.id IS NOT NULL AND i.id_schoolYear = 1 AND i.estado <> 'ANULADA' THEN 1 ELSE 0 END) AS ocupados, 13 AS `_filtro_id_grado`, 2 AS `_filtro_id_escuela`, 1 AS `_filtro_id_schoolyear`, 4 AS `_filtro_id_servicio`, 1 AS `_filtro_id_salida`
FROM `cursos` `c`
JOIN `cursos_base` `cb` ON `cb`.`id` = `c`.`id_cursos_base`
LEFT JOIN `inscripciones` `i` ON `i`.`id_curso` = `c`.`id`
WHERE `c`.`activo` = 1
AND `c`.`id_schoolyear` = 1
AND `cb`.`id_grado` = 13
AND `cb`.`id_servicio` = 4
AND `cb`.`id_escuela` = 2
AND `cb`.`id_salida_tecnica` = 1
GROUP BY `c`.`id`, `cb`.`nombre_curso`, `c`.`capacidad`
ORDER BY `cb`.`nombre_curso` ASC
