        SELECT
            c.id,
            cb.nombre_curso AS nombre_curso,
            c.capacidad,
            SUM(CASE WHEN i.id IS NOT NULL
                     AND i.id_schoolYear = ?
                     AND i.estado <> 'ANULADA'
                     THEN 1 ELSE 0 END) AS ocupados
        FROM cursos c
        JOIN cursos_base cb ON cb.id = c.id_cursos_base
        LEFT JOIN inscripciones i ON i.id_curso = c.id
